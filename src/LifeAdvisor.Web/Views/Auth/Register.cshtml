@model LifeAdvisor.Web.Models.RegisterViewModel
@{
    Layout = "_Layout";
    ViewData["Title"] = "Create Account";
}

<div class="auth-wrapper">
    <div class="auth-card">

        <div class="auth-logo">
            <span class="auth-logo-icon">✦</span>
            <span class="auth-logo-text">Digital Twin</span>
        </div>

        <h2 class="auth-title">Create your account</h2>
        <p class="auth-subtitle">Start building your digital twin</p>

        @if (!ViewData.ModelState.IsValid)
        {
            <div class="auth-error">
                @Html.ValidationSummary(false)
            </div>
        }

        <form method="post">
            @Html.AntiForgeryToken()

            <div class="auth-field">
                <label asp-for="FullName">Full name</label>
                <input asp-for="FullName" class="auth-input" placeholder="Your name" />
                <span asp-validation-for="FullName" class="validation-message"></span>
            </div>

            <div class="auth-field">
                <label asp-for="Email">Email</label>
                <input asp-for="Email" class="auth-input" placeholder="you@example.com" />
                <span asp-validation-for="Email" class="validation-message"></span>
            </div>

            <div class="auth-field">
                <label asp-for="Password">Password</label>
                <div class="auth-input-wrap">
                    <input asp-for="Password" id="password" class="auth-input" type="password" placeholder="Create a password" />
                    <button type="button" class="auth-eye" onclick="togglePassword()">👁</button>
                </div>
                <span asp-validation-for="Password" class="validation-message"></span>
            </div>

            <div class="auth-field">
                <label asp-for="DateOfBirth">Date of Birth</label>
                <input asp-for="DateOfBirth" class="auth-input" type="date" />
                <span asp-validation-for="DateOfBirth" class="validation-message"></span>
            </div>

            <div class="auth-field">
                <label asp-for="City">City</label>
                <input asp-for="City" class="auth-input" placeholder="London" />
                <span asp-validation-for="City" class="validation-message"></span>
            </div>

            <div class="auth-field">
                <label asp-for="Country">Country</label>
                <input asp-for="Country" class="auth-input" placeholder="UK" />
                <span asp-validation-for="Country" class="validation-message"></span>
            </div>

            <button type="submit" class="auth-btn">Create account</button>
        </form>

        <p class="auth-terms">
            By creating an account, you agree to our <a href="#">Terms of Service</a> and <a href="#">Privacy Policy</a>.
        </p>

        <p class="auth-switch">
            Already have an account? <a href="/Auth/Login">Log in</a>
        </p>
    </div>
</div>

<script>
    function togglePassword() {
        const input = document.getElementById('password');
        input.type = input.type === 'password' ? 'text' : 'password';
    }
</script>
