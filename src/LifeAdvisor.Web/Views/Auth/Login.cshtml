@model LifeAdvisor.Web.Models.LoginViewModel
@{
    Layout = "_Layout";
    ViewData["Title"] = "Login";
}

<div class="auth-wrapper">
    <div class="auth-card">

        <div class="auth-logo">
            <span class="auth-logo-icon">✦</span>
            <span class="auth-logo-text">Digital Twin</span>
        </div>

        <h2 class="auth-title">Welcome back</h2>
        <p class="auth-subtitle">Sign in to your account</p>

        @if (!ViewData.ModelState.IsValid)
        {
            <div class="auth-error">
                @Html.ValidationSummary(false)
            </div>
        }

        <form method="post">
            @Html.AntiForgeryToken()

            <div class="auth-field">
                <label asp-for="Email">Email</label>
                <input asp-for="Email" class="auth-input" placeholder="you@example.com" />
                <span asp-validation-for="Email" class="validation-message"></span>
            </div>

            <div class="auth-field">
                <label asp-for="Password">Password</label>
                <div class="auth-input-wrap">
                    <input asp-for="Password" id="password" class="auth-input" type="password" placeholder="Your password" />
                    <button type="button" class="auth-eye" onclick="togglePassword()">👁</button>
                </div>
                <span asp-validation-for="Password" class="validation-message"></span>
            </div>

            <button type="submit" class="auth-btn">Sign in</button>
        </form>

        <p class="auth-switch">
            Don't have an account? <a href="/Auth/Register">Create one</a>
        </p>
    </div>
</div>

<script>
    function togglePassword() {
        const input = document.getElementById('password');
        input.type = input.type === 'password' ? 'text' : 'password';
    }
</script>
