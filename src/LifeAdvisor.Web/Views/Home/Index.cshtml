@{
    Layout = "_Layout";
    ViewData["Title"] = "Home";
}

<!-- NAV -->
<nav class="home-nav">
    <div class="home-nav-logo">
        <span class="auth-logo-icon">✦</span>
        <span class="auth-logo-text">LifeAdvisor</span>
    </div>
    <div class="home-nav-links">
        <a href="/Auth/Login" class="hero-btn-outline" style="padding: 1.5px; border-radius: 8px;">
            <span class="hero-btn-outline-inner" style="padding: 0.4rem 1.2rem; font-size: 0.85rem;">Login</span>
        </a>
        <a href="/Auth/Register" class="home-nav-cta">Get Started</a>
    </div>
</nav>

<!-- HERO -->
<section class="hero">
    <div class="hero-grid-bg"></div>
    <div class="hero-glow"></div>
    <div class="hero-glow hero-glow-2"></div>
    <div class="hero-content">
        <div class="hero-badge">✦ AI-Powered Life Guidance</div>
        <h1 class="hero-title">
            Build Your
            <span class="hero-title-gradient">Digital Twin</span>
        </h1>
        <p class="hero-subtitle">
            A personalized AI model of you — your values, your goals, your story.
            Get guidance that actually understands who you are.
        </p>
        <div class="hero-actions">
            <a href="/Auth/Register" class="hero-btn-primary">
                <span>Start for free</span>
                <span class="hero-btn-arrow">→</span>
            </a>
            <a href="/Auth/Login" class="hero-btn-outline">
                <span class="hero-btn-outline-inner">Sign in</span>
            </a>
        </div>
        <p class="hero-social-proof">✦ Join thousands building their digital twin</p>
    </div>
</section>

<!-- FEATURES -->
<section class="features">
    <div class="features-grid">
        <div class="feature-card">
            <div class="feature-icon">🧠</div>
            <h3>Deep Self-Model</h3>
            <p>Your twin learns from your defining moments, decisions, and values to build a real model of who you are.</p>
        </div>
        <div class="feature-card">
            <div class="feature-icon">🎯</div>
            <h3>Life Domain Focus</h3>
            <p>Choose what matters — career, health, relationships — and get guidance tailored to those areas.</p>
        </div>
        <div class="feature-card">
            <div class="feature-icon">🔒</div>
            <h3>Private & Secure</h3>
            <p>Your personal narrative stays yours. End-to-end encryption and full data ownership.</p>
        </div>
    </div>
</section>

<!-- FOOTER -->
<footer class="home-footer">
    <p>© 2025 LifeAdvisor · Built with purpose</p>
</footer>
